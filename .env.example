# Required in production
SECRET_KEY=replace-with-strong-random-secret

# Admin lock (comma-separated)
ADMIN_EMAILS=admin@example.com

# One of the following DB options
# DATABASE_URL=sqlite:///proofloop.db
SQLITE_PATH=proofloop.db

# Flask runtime
FLASK_DEBUG=0
APP_BASE_URL=https://your-app-url.example

# SMTP reminder settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=replace-me
SMTP_FROM_EMAIL=ProofLoop <mailer@example.com>
SMTP_USE_TLS=true
